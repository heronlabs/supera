{
  "author": "Lucas Lacerda",
  "bugs": {
    "url": "https://github.com/heronlabs/supera/issues"
  },
  "description": "A repo-agnostic change-shipping superagent for Claude Code. Install once; ship changes on any repository with the same pattern — task → worktree → implement + test → PR → babysit CI → done. The PR is the unit of work — there is no external tracker.",
  "devDependencies": {
    "@types/node": "^26",
    "ajv": "^8",
    "ajv-formats": "^3",
    "eslint": "^10",
    "eslint-plugin-jsonc": "^3",
    "eslint-plugin-yml": "^3",
    "gts": "^7.0.0",
    "jiti": "^2",
    "typescript": "~6.0",
    "typescript-eslint": "^8",
    "yaml": "^2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "homepage": "https://github.com/heronlabs/supera#readme",
  "keywords": [
    "claude-code",
    "plugin",
    "workflow",
    "agents",
    "shipping",
    "ci",
    "refactor",
    "heronlabs"
  ],
  "license": "MIT",
  "name": "supera",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "tmp@<0.2.6": ">=0.2.6 <0.3"
    }
  },
  "prettier": "gts/.prettierrc.json",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heronlabs/supera.git"
  },
  "scripts": {
    "lint:check": "gts lint && eslint \"**/*.json\" \"**/*.yml\" \"**/*.yaml\" --no-error-on-unmatched-pattern",
    "lint:fix": "gts fix && eslint \"**/*.json\" \"**/*.yml\" \"**/*.yaml\" --fix --no-error-on-unmatched-pattern",
    "validate": "jiti scripts/validate.ts"
  },
  "version": "0.31.0"
}
