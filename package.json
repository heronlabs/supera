{
  "author": "Lucas Lacerda",
  "bugs": {
    "url": "https://github.com/heronlabs/supera/issues"
  },
  "description": "A repo-agnostic change-shipping superagent for Claude Code. Install once; ship changes on any repository with the same pattern — task → worktree → implement + test → PR → babysit CI → done. The PR is the unit of work — there is no external tracker.",
  "devDependencies": {
    "eslint": "^9",
    "eslint-plugin-jsonc": "^3",
    "eslint-plugin-yml": "^3",
    "gts": "^7.0.0",
    "prettier": "^3"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "homepage": "https://github.com/heronlabs/supera#readme",
  "keywords": [
    "claude-code",
    "plugin",
    "workflow",
    "agents",
    "shipping",
    "ci",
    "refactor",
    "heronlabs"
  ],
  "license": "MIT",
  "name": "supera",
  "packageManager": "pnpm@10.30.3",
  "prettier": "gts/.prettierrc.json",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heronlabs/supera.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:check": "eslint . --no-error-on-unmatched-pattern && prettier --check .",
    "lint:fix": "eslint . --fix --no-error-on-unmatched-pattern && prettier --write ."
  },
  "version": "0.28.2"
}
