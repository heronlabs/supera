{
  "stack": "cargo",
  "verify": {
    "install": "cargo fetch",
    "build": "cargo build --workspace",
    "test": "cargo test --workspace",
    "lint": "cargo clippy --workspace -- -D warnings"
  },
  "worktree": { "dir": ".worktrees", "base": "main" },
  "clickup": { "listId": "901415284967", "projectTag": "terminal-cli" },
  "pr": { "base": "main", "remote": "origin" },
  "audits": { "supplyChain": true },
  "ci": { "provider": "github", "audit": { "cargo": "cargo audit --json" } },
  "automation": { "audit": { "schedule": true, "dispatch": true } }
}
