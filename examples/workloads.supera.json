{
  "stack": "pnpm",
  "verify": {
    "install": "pnpm install --frozen-lockfile",
    "build": "pnpm turbo run build",
    "test": "pnpm turbo run test:unit",
    "lint": "pnpm lint:check"
  },
  "worktree": { "dir": ".worktrees", "base": "main" },
  "clickup": {
    "listId": "901415284967",
    "projectTag": "workloads",
    "statuses": {
      "ready": "pending",
      "building": "in progress",
      "review": "in review",
      "blocked": "blocked",
      "rejected": "rejected",
      "closed": "closed"
    }
  },
  "pr": { "base": "main", "remote": "origin" },
  "audits": { "supplyChain": true, "freshness": { "level": "patch", "minReleaseAgeDays": 7 } },
  "ci": { "provider": "github", "audit": { "pnpm": "pnpm audit --json" } },
  "automation": { "audit": { "schedule": true, "dispatch": true, "label": true } },
  "review": { "consensus": { "voters": 2 } },
  "security": { "denyPaths": ["**/.env", "**/.env.*", "**/*.pem", "**/*.key"] }
}
